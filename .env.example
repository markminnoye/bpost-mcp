# -----------------------------------------------------------------------------
# BPost MCP Environment Variables Template
# -----------------------------------------------------------------------------

# 1. Database (Neon Postgres)
# Vercel automatically prefixes these with BPOST_DB_ if using the integration.
# Locally, you can use DATABASE_URL if you prefer.
BPOST_DB_DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# 2. Security (AES-256-GCM)
# Generate using: openssl rand -base64 32
ENCRYPTION_KEY="your-32-byte-base64-key"

# 3. Authentication (Auth.js / NextAuth v5)
# Generate using: openssl rand -base64 32
AUTH_SECRET="your-random-auth-secret"

# 4. Google OAuth (Dashboard Access)
# Authorized Redirect URI: https://your-domain.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# 5. OAuth 2.0 MCP Integration (JWT Signing)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OAUTH_JWT_SECRET="generate-a-32-byte-random-secret-here"  # JWT signing (HS256)

# 6. Seeding (Demo Tenant)
# Used only by: npm run seed
SEED_BPOST_USERNAME="bpost-client-id"
SEED_BPOST_PASSWORD="bpost-password"
SEED_BPOST_CUSTOMER_NUMBER="8-digit-prs-id"
SEED_BPOST_ACCOUNT_ID="8-digit-pbc-id"
